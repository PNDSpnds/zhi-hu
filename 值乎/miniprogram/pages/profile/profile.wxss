/**profile.wxss**/

/* ==================== Page Container ==================== */
.page-container {
  padding: 20rpx 24rpx;
  padding-bottom: 80rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

/* ==================== Header Section ==================== */
.profile-header {
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.profile-header .header-top {
  align-items: flex-start;
}

.avatar-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 30rpx;
}

.avatar-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.25);
}

.avatar-emoji {
  font-size: 60rpx;
}

.avatar-edit-tip {
  margin-top: 10rpx;
  font-size: 20rpx;
}

.header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname-row {
  margin-bottom: 16rpx;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-icon {
  font-size: 28rpx;
  color: #4A90D9;
  margin-left: 10rpx;
}

.stats-row {
  justify-content: flex-start;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 140rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 4rpx;
}

.stat-divider {
  width: 2rpx;
  height: 50rpx;
  background: #E8E8E8;
  margin: 0 10rpx;
}

/* ==================== First-time Setup ==================== */
.setup-section {
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.setup-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 10rpx;
}

.setup-desc {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 36rpx;
}

.setup-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

/* Mini avatar grid for setup */
.avatar-mini-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.avatar-mini-item {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.avatar-mini-selected {
  border-color: #4A90D9;
  background: #EBF3FC;
  transform: scale(1.1);
}

.setup-input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-bottom: 30rpx;
}

.setup-actions {
  display: flex;
  justify-content: center;
}

.setup-btn {
  width: 360rpx;
}

/* ==================== Sections ==================== */
.section {
  padding: 0;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  padding: 28rpx 30rpx 0;
}

.section-header {
  padding: 28rpx 30rpx 0;
}

.section-count {
  font-size: 24rpx;
}

/* ==================== Preset Row ==================== */
.preset-row {
  padding: 24rpx 30rpx 28rpx;
}

.preset-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  background: #F0F6FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preset-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.preset-desc {
  margin-top: 4rpx;
}

.arrow {
  font-size: 28rpx;
  color: #CCCCCC;
}

/* ==================== Setting Row ==================== */
.setting-row {
  padding: 28rpx 30rpx;
}

.setting-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #4A90D9;
}

/* ==================== Weight Sliders ==================== */
.weight-sliders {
  padding: 0 30rpx 28rpx;
  border-top: 2rpx solid #F0F0F0;
}

.sliders-hint {
  padding: 20rpx 0 10rpx;
  line-height: 1.5;
}

.slider-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.slider-item:last-child {
  border-bottom: none;
}

.slider-header {
  margin-bottom: 8rpx;
}

.slider-label {
  font-size: 28rpx;
  color: #555;
}

.slider-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A90D9;
  min-width: 50rpx;
  text-align: right;
}

.slider-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  gap: 20rpx;
}

.slider-reset-btn {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
}

.slider-save-btn {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
}

/* ==================== List Items ==================== */
.list-item {
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-left {
  flex: 1;
  overflow: hidden;
}

.list-item-title {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 6rpx;
}

.list-item-date {
  font-size: 22rpx;
}

.list-item-right {
  margin-left: 16rpx;
}

.score-badge {
  width: 72rpx;
  height: 44rpx;
  border-radius: 22rpx;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.vote-mini {
  font-size: 24rpx;
  margin-right: 12rpx;
}

/* ==================== Empty State ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 30rpx;
}

.empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
}

/* ==================== Footer ==================== */
.footer {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
}

.about-row {
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #333;
}

.version {
  margin-top: 10rpx;
  text-align: center;
}

/* ==================== Avatar Grid (Picker Modal) ==================== */
.avatar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  padding: 10rpx 0 20rpx;
  justify-content: center;
}

.avatar-grid-item {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 5rpx solid transparent;
  transition: all 0.2s;
}

.avatar-grid-selected {
  border-color: #4A90D9;
  transform: scale(1.12);
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
}

.avatar-grid-emoji {
  font-size: 40rpx;
}

/* ==================== Modal System ==================== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 620rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 40rpx 36rpx 30rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-sizing: border-box;
}

.modal-small {
  width: 540rpx;
  padding: 36rpx 32rpx 28rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-actions {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.modal-actions .btn-ghost,
.modal-actions .btn-primary {
  width: 200rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
}

/* ==================== Nickname Edit Modal ==================== */
.nickname-input {
  width: 100%;
  height: 80rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  box-sizing: border-box;
  margin-bottom: 4rpx;
}

/* ==================== Preset Picker Modal ==================== */
.preset-option {
  padding: 22rpx 16rpx;
  border-radius: 14rpx;
  margin-bottom: 12rpx;
  background: #F9F9F9;
  transition: all 0.15s;
}

.preset-option-active {
  background: #EBF3FC;
  border: 2rpx solid #4A90D9;
}

.preset-option-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 60rpx;
  text-align: center;
}

.preset-option-info {
  flex: 1;
}

.preset-option-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

.preset-option-desc {
  margin-top: 2rpx;
}

.preset-check {
  font-size: 32rpx;
  color: #4A90D9;
  font-weight: 700;
}

/* ==================== About Modal ==================== */
.about-content {
  text-align: center;
  padding: 10rpx 0;
}

.about-app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #4A90D9;
  margin-bottom: 16rpx;
}

.about-desc {
  font-size: 28rpx;
  line-height: 1.7;
}

.about-version {
  padding-top: 10rpx;
}

/* ==================== Misc ==================== */
.list-item .arrow {
  font-size: 24rpx;
  margin-left: 8rpx;
}
