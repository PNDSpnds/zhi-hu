/* ====== result 结果页 ====== */
.result-page {
  min-height: 100vh;
  padding: 30rpx 30rpx 80rpx;
  box-sizing: border-box;
}

/* 分数卡片 */
.result-card-section {
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border-radius: 16rpx;
}

/* ---- 深入评测 CTA ---- */
.extended-cta {
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.cta-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.cta-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 24rpx;
}

.cta-title {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.cta-desc {
  line-height: 1.5;
  max-width: 460rpx;
}

.cta-btn {
  width: 100%;
  max-width: 500rpx;
  border-radius: 44rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

/* ---- 维度建议 ---- */
.advice-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  color: #1A1A1A;
  margin-bottom: 20rpx;
}

.advice-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.advice-good {
  border-left: 6rpx solid #4A90D9;
  background: #F0F7FF;
}

.advice-bad {
  border-left: 6rpx solid #E8636C;
  background: #FFF5F5;
}

.advice-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
  align-self: flex-start;
  margin-top: 6rpx;
}

.dot-good {
  background: #4A90D9;
}

.dot-bad {
  background: #E8636C;
}

.advice-content {
  flex: 1;
}

.advice-dim {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.advice-text {
  line-height: 1.5;
}

/* ---- 操作按钮 ---- */
.result-actions {
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  width: 100%;
  border-radius: 44rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-share {
  background: linear-gradient(135deg, #4A90D9, #6DB3F2);
  color: #FFFFFF;
  border-radius: 44rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  line-height: 1;
}

.btn-share::after {
  border: none;
}

.btn-share:active {
  opacity: 0.85;
}

/* ---- 底部提示 ---- */
.result-tip {
  padding: 20rpx 0;
}
