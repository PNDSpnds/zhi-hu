/* pages/index/index.wxss — Community Feed */

page {
  background-color: #F5F5F5;
}

.feed-container {
  padding: 16rpx;
  min-height: 100vh;
}

/* ===== Waterfall Grid ===== */
.waterfall {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: flex-start;
}

.waterfall-column {
  width: calc(50% - 8rpx);
  display: flex;
  flex-direction: column;
}

/* ===== Feed Card ===== */
.feed-card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.feed-card:active {
  opacity: 0.85;
}

.card-item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-top: 12rpx;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== Author Row ===== */
.card-author {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.card-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #E8F0FE;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.card-avatar.avatar-anon {
  background-color: #E0E0E0;
  color: #999;
  font-size: 20rpx;
}

.card-nickname {
  font-size: 22rpx;
  color: #666666;
  margin-left: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-nickname.anonymous {
  color: #999999;
  font-style: italic;
}

/* ===== Empty State ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon-text {
  font-size: 100rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  color: #999999;
  margin-top: 30rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #BBBBBB;
  margin-top: 10rpx;
}

/* ===== Load More ===== */
.load-more {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 30rpx 0 60rpx;
  font-size: 24rpx;
  color: #BBBBBB;
}

/* ===== Utility ===== */
.text-muted {
  color: #999999;
}
